# AncientChinese-Tagger 环境变量模板

# 后端配置 (详见 backend/.env.example)
DEEPSEEK_API_KEY=your_deepseek_api_key
JWT_SECRET=your_jwt_secret

# 数据库配置
DB_PASSWORD=dev123
DB_ROOT_PASSWORD=root123

# 前端配置
VITE_API_URL=http://localhost:8080
VITE_USE_MOCK=false

# GitHub 仓库路径 (用于生产环境镜像)
GITHUB_REPOSITORY=your-username/AncientChinese-Tagger
